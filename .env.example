# Database
DATABASE_URL=postgres://weepost:weepost@localhost:5432/weepost?sslmode=disable

# JWT
JWT_SECRET=change-me-in-production-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-in-production-min-32!!
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Argon2id pepper (auth passwords)
ARGON2_PEPPER=change-me-pepper-min-32-chars-here!!

# AES-256-GCM key for token encryption (exactly 32 bytes)
CRYPTO_KEY=change-me-32-bytes-key-here-!!!!!!

# App
APP_PORT=3000
APP_ENV=development

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3001
